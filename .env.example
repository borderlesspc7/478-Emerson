# Web Firebase: ver src/lib/firebase.ts (não usar VITE_* para este projeto)

# API Stays (hóspede) — App Center: Stays API / External API ativa + credenciais
# CORS: no `npm run dev` o Vite reencaminha de /__stays (mesma origem) para a API. Defina a URL completa
#   em VITE_STAYS_BASE_URL para o proxy (e para o build).
# Em produção (Firebase Hosting), o frontend usa /api/stays (Cloud Function) e as credenciais NÃO vão no bundle:
#   defina STAYS_* em functions/.env (local) ou Firebase Console → Functions → Environment variables (prod).
# VITE_STAYS_NO_DEV_PROXY=1 desactiva o proxy em DEV.
VITE_STAYS_BASE_URL=https://bsc.stays.com.br/external/v1
VITE_STAYS_LOGIN=
VITE_STAYS_PASSWORD=

# Stays — servidor (functions/.env e Firebase Console)
STAYS_BASE_URL=https://bsc.stays.com.br/external/v1
STAYS_LOGIN=
STAYS_PASSWORD=

# Suporte Zen — página Extras (WhatsApp, só dígitos com DDI, ex. 5541999999999)
VITE_ZEN_SUPPORT_WHATSAPP=

# Storage (scripts Node locais)
FIREBASE_STORAGE_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=

# Pagar.me — pagamentos de serviços (PIX ou cartão à vista)
# Obtenha em dash.pagar.me → Configurações → Chaves de API (sandbox: pk_test_… / sk_test_…)
# Frontend (tokenização cartão):
VITE_PAGARME_PUBLIC_KEY=
# Servidor — duplicar em functions/.env e no Firebase Console (Functions):
PAGARME_SECRET_KEY=
PAGARME_WEBHOOK_USER=
PAGARME_WEBHOOK_PASSWORD=

# Dev local — emulador Firebase Functions (npm run dev:api)
VITE_FIREBASE_PROJECT_ID=emerson-1e6d2
VITE_FIREBASE_FUNCTIONS_REGION=southamerica-east1
VITE_FIREBASE_FUNCTIONS_EMULATOR_HOST=127.0.0.1:5001
