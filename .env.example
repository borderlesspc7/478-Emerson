# Web Firebase: ver src/lib/firebase.ts (não usar VITE_* para este projeto)

# API Stays (hóspede) — App Center: Stays API / External API ativa + credenciais
# CORS: no `npm run dev` o Vite reencaminha de /__stays (mesma origem) para a API. Defina a URL completa
#   em VITE_STAYS_BASE_URL para o proxy (e para o build). Em produção estática, um proxy
#   no backend ou Cloud Function é necessário se o browser ainda tiver CORS. VITE_STAYS_NO_DEV_PROXY=1 desactiva o proxy.
# 401: id/secret errados, espaços no .env, URL de outro ambiente; reiniciar o dev após alterar.
# VITE_STAYS_LOGIN    = client id (não a senha do site Stays)
# VITE_STAYS_PASSWORD = client secret
# Código: no site ?reserve=XXXX. Base: …/external/v1 (não use a URL /i/account-overview do browser)
# Ex.: https://SEU_TENANT.stays.com.br/external/v1
VITE_STAYS_BASE_URL=https://bsc.stays.com.br/external/v1
VITE_STAYS_LOGIN=39ef30e
VITE_STAYS_PASSWORD=06ce0efa

# Servidor (firebase-admin / scripts Node)
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_STORAGE_BUCKET=
