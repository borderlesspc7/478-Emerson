rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin: perfil Firestore com role explícita OU documento legado sem `role` mas
    // JWT com e-mail corporativo (não @zen.com.br). Alinha com `syncUserProfileToFirestore`,
    // que grava `role: admin` para estes e-mails — evita negar escrita quando o doc
    // ainda não tem o campo (UI antiga inferia admin só pelo e-mail).
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          || (
            !('role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
            && request.auth.token.email != null
            && !(request.auth.token.email.matches('(?i).+@zen\\.com\\.br$'))
          )
        );
    }

    function isGuestUser() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'guest';
    }

    function guestReservationCodeMatches(reservationCode) {
      return isGuestUser()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.reservationCode == reservationCode;
    }

    function guestAccessUsageUpdateOnly(reservationCode) {
      return guestReservationCodeMatches(reservationCode)
        && request.resource.data.propertyId == resource.data.propertyId
        && request.resource.data.reservationCode == resource.data.reservationCode
        && request.resource.data.accessActive == resource.data.accessActive
        && (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt)
        && (!('updatedAt' in resource.data) || request.resource.data.updatedAt == resource.data.updatedAt)
        && (
          (!('customFieldVisibility' in resource.data) && !('customFieldVisibility' in request.resource.data))
          || request.resource.data.customFieldVisibility == resource.data.customFieldVisibility
        )
        && request.resource.data.lastAccessAt is timestamp
        && request.resource.data.deviceInfo is string
        && request.resource.data.deviceInfo.size() > 0
        && request.resource.data.deviceInfo.size() <= 500
        && request.resource.data.accessCount is int
        && request.resource.data.accessCount >= 1
        && (
          !('accessCount' in resource.data)
          || request.resource.data.accessCount == resource.data.accessCount + 1
        );
    }

    function securityLogCreateValid() {
      let d = request.resource.data;
      return d.keys().hasOnly(['attemptedReservationCode', 'reason', 'deviceInfo', 'createdAt'])
        && d.attemptedReservationCode is string
        && d.attemptedReservationCode.size() > 0
        && d.attemptedReservationCode.size() <= 40
        && d.reason is string
        && d.reason.size() > 0
        && d.reason.size() <= 96
        && d.deviceInfo is string
        && d.deviceInfo.size() <= 400
        && d.createdAt is timestamp;
    }

    function fcmTokenWriteValid() {
      let d = request.resource.data;
      return d.keys().hasAll(['userId', 'token', 'platform', 'active', 'updatedAt'])
        && d.userId is string
        && d.userId == request.auth.uid
        && d.token is string
        && d.token.size() > 0
        && d.token.size() <= 4096
        && d.platform == 'web'
        && d.active is bool
        && d.updatedAt is timestamp
        && (!('userAgent' in d) || (d.userAgent is string && d.userAgent.size() <= 400))
        && (!('createdAt' in d) || d.createdAt is timestamp);
    }

    // Perfil do utilizador autenticado (sincronizado com Firebase Auth)
    match /users/{userId} {
      allow read, create, update: if request.auth != null
        && request.auth.uid == userId;
      allow delete: if false;
    }

    // Tokens FCM web — o hóspede gere os seus dispositivos
    match /fcmTokens/{tokenId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && fcmTokenWriteValid();
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && fcmTokenWriteValid();
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Histórico de notificações push enviadas (escrita só servidor)
    match /notifications/{notificationId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Catálogo de serviços: leitura para autenticados; escrita só admin
    match /serviceCatalog/{itemId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // Curadoria de imóveis (fotos / textos manuais), chave = propertyId Stays
    match /propertyCurations/{propertyId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }

    // Vínculo manual reserva → imóvel (prioridade no Guia Zen)
    match /guestAccessLinks/{reservationCode} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || guestAccessUsageUpdateOnly(reservationCode);
    }

    // Tentativas de login hóspede falhadas (sem auth obrigatório; payload limitado)
    match /securityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if securityLogCreateValid();
      allow update, delete: if false;
    }

    // Pagamentos de serviços: criados no servidor (Pagar.me); hóspede só lê o seu
    match /servicePayments/{paymentId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Pedidos de serviço: criados só após pagamento aprovado (servidor / webhook)
    match /serviceRequests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if false;

      allow update: if isAdmin()
        && request.resource.data.userId == resource.data.userId;

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
